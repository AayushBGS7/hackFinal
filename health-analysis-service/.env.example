# Required environment variables for the Rural Health Analysis Service

# Your Google Gemini API key (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Port the Flask server runs on (default: 5050)
FLASK_PORT=5050

# Maximum allowed upload file size in MB (default: 10)
MAX_FILE_SIZE_MB=10

